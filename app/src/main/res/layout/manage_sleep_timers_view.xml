<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:id="@+id/sleep_timer_presets_root"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#CC000000"
        android:clickable="true"
        android:focusable="true">

    <com.google.android.material.card.MaterialCardView
            android:id="@+id/sleep_timer_presets_sheet"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            app:cardElevation="12dp"
            app:cardPreventCornerOverlap="false"
            app:cardUseCompatPadding="false"
            app:rippleColor="@color/transparent"
            app:shapeAppearanceOverlay="@style/SpotifyPlus_BottomSheetShape"
            app:strokeWidth="0dp"
            app:cardBackgroundColor="@color/spotifyplus_background">

        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingTop="12dp"
                android:paddingEnd="20dp"
                android:paddingBottom="24dp">

            <View
                    android:id="@+id/sleep_timer_presets_sheet_handle"
                    android:layout_width="42dp"
                    android:layout_height="4dp"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginBottom="18dp"
                    android:background="@drawable/spotifyplus_bottom_sheet_handle"/>

            <LinearLayout
                    android:id="@+id/sleep_timer_presets_header"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="6dp">

                <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                    <TextView
                            android:id="@+id/sleep_timer_presets_title"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Custom Sleep Timers"
                            android:textColor="@color/white"
                            android:textSize="22sp"
                            android:textStyle="bold"/>

                    <TextView
                            android:id="@+id/sleep_timer_presets_description"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Reorder or delete the presets shown in your sleep timer list."
                            android:textColor="@color/spotifyplus_onSurface"
                            android:textSize="14sp"
                            android:layout_marginTop="4dp"/>

                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                    android:id="@+id/sleep_timer_auto_reorder_row"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp">

                <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                    <TextView
                            android:id="@+id/sleep_timer_auto_reorder_title"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Auto reorder"
                            android:textColor="@color/white"
                            android:textSize="15sp"
                            android:textStyle="bold"/>

                    <TextView
                            android:id="@+id/sleep_timer_auto_reorder_description"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Automatically sort presets by duration."
                            android:textColor="@color/spotifyplus_onSurface"
                            android:textSize="13sp"
                            android:layout_marginTop="2dp"/>

                </LinearLayout>

                <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switch_sleep_timer_auto_reorder"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

            </LinearLayout>

            <TextView
                    android:id="@+id/sleep_timer_presets_hint"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Hold and drag a preset to reorder it."
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="13sp"
                    android:layout_marginTop="10dp"
                    android:layout_marginBottom="12dp"/>

            <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recycler_sleep_timer_presets"
                    android:layout_width="match_parent"
                    android:layout_height="320dp"
                    android:clipToPadding="false"
                    android:overScrollMode="never"
                    android:paddingBottom="8dp"/>

            <TextView
                    android:id="@+id/sleep_timer_presets_empty"
                    android:layout_width="match_parent"
                    android:layout_height="160dp"
                    android:gravity="center"
                    android:text="You don't have any custom presets yet."
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="14sp"
                    android:visibility="gone"/>

            <com.google.android.material.divider.MaterialDivider
                    android:id="@+id/sleep_timer_presets_divider"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="14dp"
                    app:dividerColor="#22FFFFFF"/>

            <LinearLayout
                    android:id="@+id/sleep_timer_presets_buttons"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="end">

                <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_cancel_sleep_timer_presets"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Cancel"
                        android:textAllCaps="false"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:layout_marginEnd="8dp"/>

                <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_save_sleep_timer_presets"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Save"
                        android:textAllCaps="false"/>

            </LinearLayout>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</FrameLayout>