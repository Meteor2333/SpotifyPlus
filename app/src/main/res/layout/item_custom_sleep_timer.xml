<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:id="@+id/sleep_timer_preset_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        app:cardCornerRadius="14dp"
        app:cardElevation="0dp"
        app:strokeWidth="1dp"
        app:strokeColor="#22FFFFFF"
        app:cardBackgroundColor="#12FFFFFF">

    <LinearLayout
            android:id="@+id/sleep_timer_preset_row"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="14dp"
            android:paddingEnd="8dp">

        <ImageView
                android:id="@+id/sleep_timer_preset_drag_handle"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_marginEnd="12dp"
                android:src="@drawable/reorder"
                app:tint="@color/spotifyplus_onSurfaceSecondary"
                android:contentDescription="Drag to reorder"/>

        <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

            <TextView
                    android:id="@+id/sleep_timer_preset_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="30 minutes"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:textStyle="bold"/>

        </LinearLayout>

        <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_delete_sleep_timer_preset"
                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:contentDescription="Delete preset"
                app:icon="@drawable/delete"
                app:iconTint="?attr/colorOnSurfaceVariant"/>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>