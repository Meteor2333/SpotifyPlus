<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.circularreveal.coordinatorlayout.CircularRevealCoordinatorLayout
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:id="@+id/settings_root"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fitsSystemWindows="true"
        android:background="@color/spotifyplus_background">

    <!-- App bar with collapsing header -->
    <com.google.android.material.appbar.AppBarLayout
            android:id="@+id/appbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:liftOnScroll="true">

        <com.google.android.material.appbar.MaterialToolbar
                android:id="@+id/lyrics_toolbar"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#272727"
                android:gravity="center"
                app:titleCentered="true"
                app:title="Beautiful Lyrics"
                app:titleTextAppearance="@style/TextAppearance.Material3.TitleMedium"
                app:navigationIcon="?attr/homeAsUpIndicator"/>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView android:layout_width="match_parent" android:layout_height="match_parent"
                                           android:paddingTop="16dp" android:paddingStart="16dp"
                                           android:clickable="true" android:focusable="true"
                                           app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                      android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                      android:text="Visuals" style="@style/TextAppearance.Material3.TitleLarge"
                      android:paddingBottom="12dp"/>

            <RadioGroup
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="24dp"
                    android:clickable="true" android:focusable="true"
                    android:background="@drawable/row_click_bg">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                              android:orientation="vertical">
                    <LinearLayout
                            android:layout_height="0dp"
                            android:layout_width="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                        <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Animation Style"
                                android:textColor="@color/white"
                                android:textSize="15sp"
                                android:paddingBottom="4dp"
                        />

                        <TextView
                                style="@style/TextAppearance.Material3.BodySmall"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Whether lyrics should be animated more like Beautiful Lyrics or Apple Music"
                                android:textColor="?attr/colorOnSurfaceVariant"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                                  android:orientation="horizontal">

                        <LinearLayout android:layout_width="0dp" android:layout_weight="1"
                                      android:layout_height="wrap_content" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="48dp"
                                      android:text="Beautiful Lyrics" style="@style/TextAppearance.Material3.BodyMedium"
                                      android:gravity="center_vertical"/>

                            <TextView android:layout_width="wrap_content" android:layout_height="48dp"
                                      android:text="Apple Music" style="@style/TextAppearance.Material3.BodyMedium"
                                      android:gravity="center_vertical"/>
                        </LinearLayout>

                        <LinearLayout android:layout_width="0dp" android:layout_weight="1"
                                      android:layout_height="wrap_content"
                                      android:orientation="vertical" android:gravity="end">

                            <com.google.android.material.radiobutton.MaterialRadioButton
                                    android:id="@+id/rb_beautiful_lyrics_anim"
                                    android:layout_width="wrap_content"
                                    android:layout_height="48dp"
                                    android:checked="true"/>

                            <com.google.android.material.radiobutton.MaterialRadioButton
                                    android:id="@+id/rb_apple_music_anim"
                                    android:layout_width="wrap_content"
                                    android:layout_height="48dp"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </RadioGroup>

            <RadioGroup
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="24dp"
                    android:clickable="true" android:focusable="true"
                    android:background="@drawable/row_click_bg">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                              android:orientation="vertical">
                    <LinearLayout
                            android:layout_height="0dp"
                            android:layout_width="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                        <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Lyrics Font"
                                android:textColor="@color/white"
                                android:textSize="15sp"
                                android:paddingBottom="4dp"
                        />

                        <TextView
                                style="@style/TextAppearance.Material3.BodySmall"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="What font to use for the lyrics"
                                android:textColor="?attr/colorOnSurfaceVariant"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                                  android:orientation="horizontal">

                        <LinearLayout android:layout_width="0dp" android:layout_weight="1"
                                      android:layout_height="wrap_content" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="48dp"
                                      android:text="Spotify" style="@style/TextAppearance.Material3.BodyMedium"
                                      android:gravity="center_vertical"/>

                            <TextView android:layout_width="wrap_content" android:layout_height="48dp"
                                      android:text="Beautiful Lyrics" style="@style/TextAppearance.Material3.BodyMedium"
                                      android:gravity="center_vertical"/>

                            <TextView android:layout_width="wrap_content" android:layout_height="48dp"
                                      android:text="Apple Music" style="@style/TextAppearance.Material3.BodyMedium"
                                      android:gravity="center_vertical"/>
                        </LinearLayout>

                        <LinearLayout android:layout_width="0dp" android:layout_weight="1"
                                      android:layout_height="wrap_content"
                                      android:orientation="vertical" android:gravity="end">

                            <com.google.android.material.radiobutton.MaterialRadioButton
                                    android:id="@+id/font_spotify"
                                    android:layout_width="wrap_content"
                                    android:layout_height="48dp"/>

                            <com.google.android.material.radiobutton.MaterialRadioButton
                                    android:id="@+id/font_beautiful_lyrics"
                                    android:layout_width="wrap_content"
                                    android:layout_height="48dp"
                                    android:checked="true"/>

                            <com.google.android.material.radiobutton.MaterialRadioButton
                                    android:id="@+id/font_apple_music"
                                    android:layout_width="wrap_content"
                                    android:layout_height="48dp"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </RadioGroup>

            <RadioGroup
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="24dp"
                    android:clickable="true" android:focusable="true"
                    android:background="@drawable/row_click_bg">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                              android:orientation="vertical">
                    <LinearLayout
                            android:layout_height="0dp"
                            android:layout_width="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                        <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Interlude Duration"
                                android:textColor="@color/white"
                                android:textSize="15sp"
                                android:paddingBottom="4dp"
                        />

                        <TextView
                                style="@style/TextAppearance.Material3.BodySmall"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="The minmum amount of time it takes for an interlude to show up"
                                android:textColor="?attr/colorOnSurfaceVariant"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                                  android:orientation="horizontal">

                        <LinearLayout android:layout_width="0dp" android:layout_weight="1"
                                      android:layout_height="wrap_content" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="48dp"
                                      android:text="Beautiful Lyrics" style="@style/TextAppearance.Material3.BodyMedium"
                                      android:gravity="center_vertical"/>

                            <TextView android:layout_width="wrap_content" android:layout_height="48dp"
                                      android:text="Spicy Lyrics" style="@style/TextAppearance.Material3.BodyMedium"
                                      android:gravity="center_vertical"/>

                            <TextView android:layout_width="wrap_content" android:layout_height="48dp"
                                      android:text="Spotify Plus" style="@style/TextAppearance.Material3.BodyMedium"
                                      android:gravity="center_vertical"/>

                            <TextView android:layout_width="wrap_content" android:layout_height="48dp"
                                      android:text="Apple Music" style="@style/TextAppearance.Material3.BodyMedium"
                                      android:gravity="center_vertical"/>
                        </LinearLayout>

                        <LinearLayout android:layout_width="0dp" android:layout_weight="1"
                                      android:layout_height="wrap_content"
                                      android:orientation="vertical" android:gravity="end">

                            <com.google.android.material.radiobutton.MaterialRadioButton
                                    android:id="@+id/rb_beautiful_lyrics_interlude"
                                    android:layout_width="wrap_content"
                                    android:layout_height="48dp"
                                    android:checked="true"/>

                            <com.google.android.material.radiobutton.MaterialRadioButton
                                    android:id="@+id/rb_spicy_lyrics_interlude"
                                    android:layout_width="wrap_content"
                                    android:layout_height="48dp"
                                    android:checked="true"/>

                            <com.google.android.material.radiobutton.MaterialRadioButton
                                    android:id="@+id/rb_spotify_plus_interlude"
                                    android:layout_width="wrap_content"
                                    android:layout_height="48dp"
                                    android:checked="true"/>

                            <com.google.android.material.radiobutton.MaterialRadioButton
                                    android:id="@+id/rb_apple_music_interlude"
                                    android:layout_width="wrap_content"
                                    android:layout_height="48dp"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </RadioGroup>

            <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="24dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="@drawable/row_click_bg"
                    android:clipChildren="false"
                    android:clipToPadding="false">

                <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Line Spacing"
                        android:textColor="@color/white"
                        android:textSize="15sp"
                        android:paddingBottom="4dp" />

                <TextView
                        style="@style/TextAppearance.Material3.BodySmall"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="The amount of space in between lines. A larger amount will have a larger font size and more space in between lines, resulting in fewer lines being visible."
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:paddingBottom="16dp" />

                <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:layout_marginRight="12dp"
                        android:clipChildren="false"
                        android:clipToPadding="false">

                    <TextView
                            android:id="@+id/line_spacing_min"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Compact"
                            android:textColor="#AFAFAF"
                            android:textSize="13sp"
                            android:paddingEnd="12dp" />

                    <FrameLayout
                            android:id="@+id/line_spacing_slider_container"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:clipChildren="false"
                            android:clipToPadding="false">

                        <TextView
                                android:id="@+id/line_spacing_value_label"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="top|start"
                                android:background="@drawable/slider_value_bubble"
                                android:text="Default"
                                android:textColor="@android:color/white"
                                android:textSize="12sp"
                                android:paddingStart="8dp"
                                android:paddingEnd="8dp"
                                android:paddingTop="4dp"
                                android:paddingBottom="4dp"
                                android:visibility="gone" />

                        <com.google.android.material.slider.Slider
                                android:id="@+id/line_spacing_slider"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_gravity="bottom"
                                android:valueFrom="0"
                                android:valueTo="4"
                                android:value="1"
                                android:stepSize="1"
                                app:labelBehavior="gone"
                                app:haloRadius="0dp"
                                app:thumbColor="@android:color/white"
                                app:thumbRadius="2dp"
                                app:trackHeight="4dp"
                                app:trackColorActive="#1ED760"
                                app:trackColorInactive="#5A5A5A"
                                app:trackStopIndicatorSize="0dp"
                                app:tickVisible="false" />
                    </FrameLayout>

                    <TextView
                            android:id="@+id/line_spacing_max"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Max"
                            android:textColor="#AFAFAF"
                            android:textSize="13sp"
                            android:paddingStart="12dp" />
                </LinearLayout>

            </LinearLayout>

            <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="24dp"
                    android:clickable="true" android:focusable="true"
                    android:background="@drawable/row_click_bg">

                <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                    <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Enable Background"
                            android:textColor="@color/white"
                            android:textSize="15sp"
                            android:paddingBottom="4dp" />

                    <TextView
                            style="@style/TextAppearance.Material3.BodySmall"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Whether the background should be an animated background or just a static color"
                            android:textColor="?attr/colorOnSurfaceVariant"/>
                </LinearLayout>

                <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switch_enable_background"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingHorizontal="8dp"
                        android:checked="true"
                        android:contentDescription="Enable Background"/>
            </LinearLayout>

            <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="24dp"
                    android:clickable="true" android:focusable="true"
                    android:background="@drawable/row_click_bg">

                <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                    <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Enable Line Lyrics Gradient"
                            android:textColor="@color/white"
                            android:textSize="15sp"
                            android:paddingBottom="4dp" />

                    <TextView
                            style="@style/TextAppearance.Material3.BodySmall"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sets whether lines should have a gradient or stay a solid color in line synced lyrics"
                            android:textColor="?attr/colorOnSurfaceVariant"/>
                </LinearLayout>

                <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switch_enable_line_gradient"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingHorizontal="8dp"
                        android:checked="true"
                        android:contentDescription="Enable Line Lyrics Gradient"/>
            </LinearLayout>

            <RadioGroup
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp"
                    android:clickable="true" android:focusable="true"
                    android:background="@drawable/row_click_bg">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                              android:orientation="vertical">
                    <LinearLayout
                            android:layout_height="0dp"
                            android:layout_width="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                        <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Background Quality"
                                android:textColor="@color/white"
                                android:textSize="15sp"
                                android:paddingBottom="4dp"
                        />

                        <TextView
                                style="@style/TextAppearance.Material3.BodySmall"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Changes the quality of the background. Lower quality should give better performance at the cost of detail and variance in colors"
                                android:textColor="?attr/colorOnSurfaceVariant"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                                  android:orientation="horizontal">

                        <LinearLayout android:layout_width="0dp" android:layout_weight="1"
                                      android:layout_height="wrap_content" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="48dp"
                                      android:text="Quality" style="@style/TextAppearance.Material3.BodyMedium"
                                      android:gravity="center_vertical"/>

                            <TextView android:layout_width="wrap_content" android:layout_height="48dp"
                                      android:text="Balanced" style="@style/TextAppearance.Material3.BodyMedium"
                                      android:gravity="center_vertical"/>

                            <TextView android:layout_width="wrap_content" android:layout_height="48dp"
                                      android:text="Performance" style="@style/TextAppearance.Material3.BodyMedium"
                                      android:gravity="center_vertical"/>

                            <TextView android:layout_width="wrap_content" android:layout_height="48dp"
                                      android:text="Ultra Performance" style="@style/TextAppearance.Material3.BodyMedium"
                                      android:gravity="center_vertical"/>
                        </LinearLayout>

                        <LinearLayout android:layout_width="0dp" android:layout_weight="1"
                                      android:layout_height="wrap_content"
                                      android:orientation="vertical" android:gravity="end">

                            <com.google.android.material.radiobutton.MaterialRadioButton
                                    android:id="@+id/rb_background_high"
                                    android:layout_width="wrap_content"
                                    android:layout_height="48dp"
                                    android:checked="true"/>

                            <com.google.android.material.radiobutton.MaterialRadioButton
                                    android:id="@+id/rb_background_mid"
                                    android:layout_width="wrap_content"
                                    android:layout_height="48dp"
                                    android:checked="true"/>

                            <com.google.android.material.radiobutton.MaterialRadioButton
                                    android:id="@+id/rb_background_low"
                                    android:layout_width="wrap_content"
                                    android:layout_height="48dp"/>

                            <com.google.android.material.radiobutton.MaterialRadioButton
                                    android:id="@+id/rb_background_superlow"
                                    android:layout_width="wrap_content"
                                    android:layout_height="48dp"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </RadioGroup>

            <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:alpha="0.08"
                    android:background="?attr/colorOnSurface"
                    android:layout_marginTop="6dp"
                    android:layout_marginBottom="16dp"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                      android:text="Privacy" style="@style/TextAppearance.Material3.TitleLarge"
                      android:paddingBottom="12dp"/>

            <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp"
                    android:clickable="true" android:focusable="true"
                    android:background="@drawable/row_click_bg">

                <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                    <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Send Access Token"
                            android:textColor="@color/white"
                            android:textSize="15sp"
                            android:paddingBottom="4dp" />

                    <TextView
                            style="@style/TextAppearance.Material3.BodySmall"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Send your Spotify access token to the Beautiful Lyrics API. If disabled, some songs will not load lyrics"
                            android:textColor="?attr/colorOnSurfaceVariant"/>
                </LinearLayout>

                <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switch_send_token"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingHorizontal="8dp"
                        android:checked="true"
                        android:contentDescription="Send Access Token"/>
            </LinearLayout>

