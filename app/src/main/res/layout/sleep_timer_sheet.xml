<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:id="@+id/sleep_timer_custom_root"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#CC000000"
        android:clickable="true"
        android:focusable="true">

    <com.google.android.material.card.MaterialCardView
            android:id="@+id/sleep_timer_custom_sheet"
            app:rippleColor="@color/transparent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            app:cardElevation="12dp"
            app:cardPreventCornerOverlap="false"
            app:cardUseCompatPadding="false"
            app:shapeAppearanceOverlay="@style/SpotifyPlus_BottomSheetShape"
            app:strokeWidth="0dp"
            app:cardBackgroundColor="@color/spotifyplus_background">

        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingTop="12dp"
                android:paddingEnd="20dp"
                android:paddingBottom="24dp">

            <View
                    android:id="@+id/sleep_timer_sheet_handle"
                    android:layout_width="42dp"
                    android:layout_height="4dp"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginBottom="18dp"
                    android:background="@drawable/spotifyplus_bottom_sheet_handle"/>

            <TextView
                    android:id="@+id/sleep_timer_custom_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Custom Sleep Timer"
                    android:textColor="@color/white"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp"/>

            <TextView
                    android:id="@+id/sleep_timer_custom_description"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Choose a custom amount of time before playback stops."
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="14sp"
                    android:layout_marginBottom="18dp"/>

            <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/sleep_timer_amount_layout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    android:hint="Amount"
                    app:boxStrokeColor="#55FFFFFF"
                    app:hintTextColor="#AAFFFFFF">

                <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/input_sleep_timer_amount"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="number"
                        android:maxLines="1"
                        android:textColor="@color/white"
                        android:textColorHint="#88FFFFFF"/>
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                    android:id="@+id/sleep_timer_unit_label"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Time unit"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

            <com.google.android.material.button.MaterialButtonToggleGroup
                    android:id="@+id/sleep_timer_unit_toggle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:singleSelection="true"
                    app:selectionRequired="true"
                    app:checkedButton="@id/btn_sleep_timer_minutes">

                <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_sleep_timer_minutes"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Minutes"
                        android:backgroundTint="@color/sleep_timer_toggle_background"
                        android:textAllCaps="false"
                        android:textColor="@color/white"/>

                <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_sleep_timer_hours"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Hours"
                        android:backgroundTint="@color/sleep_timer_toggle_background"
                        android:textAllCaps="false"
                        android:textColor="@color/white"/>

            </com.google.android.material.button.MaterialButtonToggleGroup>

            <LinearLayout
                    android:id="@+id/sleep_timer_save_row"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    android:layout_marginBottom="18dp">

                <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                    <TextView
                            android:id="@+id/sleep_timer_save_title"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Save for later"
                            android:textColor="@color/white"
                            android:textSize="15sp"
                            android:textStyle="bold"/>

                    <TextView
                            android:id="@+id/sleep_timer_save_description"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Show this custom amount in the list next time. You can manage custom timers in settings."
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:textSize="13sp"/>

                </LinearLayout>

                <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switch_sleep_timer_save"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_confirm_sleep_timer_custom"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Start Timer"
                    android:textAllCaps="false"
                    android:layout_marginBottom="10dp"/>

            <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_cancel_sleep_timer_custom"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Cancel"
                    android:textAllCaps="false"
                    android:textColor="?attr/colorOnSurfaceVariant"/>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</FrameLayout>